        </mxCell>

        <mxCell id="s3-api" value="REST API: POST /defects, GET /defects, GET /defects/:id,&lt;br&gt;PUT /defects/:id/schedule, PUT /defects/:id/close" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B3E5FC;strokeColor=#0277BD;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
