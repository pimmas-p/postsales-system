        </mxCell>

        <mxCell id="s1-input" value="INPUT (Kafka Events)&lt;br&gt;────────────────────&lt;br&gt;• managing.kyc.completed&lt;br&gt;• purchase.contract.drafted&lt;br&gt;• payment.secondpayment.completed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#424242;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="475" width="330" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s1-process" value="PROCESSING&lt;br&gt;────────────────────&lt;br&gt;• Event Handlers (handleKycEvent, etc.)&lt;br&gt;• UPSERT handover_cases by unit_id&lt;br&gt;• Calculate overall_status:&lt;br&gt;  - READY (all 3 approved)&lt;br&gt;  - BLOCKED (any rejected)&lt;br&gt;  - PENDING (incomplete)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="565" width="330" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="s1-api" value="REST API&lt;br&gt;────────────────────&lt;br&gt;GET /api/handover/cases&lt;br&gt;GET /api/handover/cases/:id&lt;br&gt;PUT /api/handover/cases/:id/complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B3E5FC;strokeColor=#0277BD;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="685" width="330" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s1-output" value="OUTPUT&lt;br&gt;────────────────────&lt;br&gt;• Kafka: postsales.handover.completed&lt;br&gt;• Auto-create onboarding_case" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="755" width="330" height="45" as="geometry"/>
        </mxCell>

