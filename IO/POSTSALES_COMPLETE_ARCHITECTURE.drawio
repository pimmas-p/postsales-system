        <mxCell id="s3-schedule" value="PHASE 3: Schedule Repair&lt;br&gt;────────────────────&lt;br&gt;• PUT /defects/:id/schedule&lt;br&gt;• Assign technician, set date&lt;br&gt;• Publish: postsales.defect.scheduled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE082;strokeColor=#F57C00;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
