        <mxCell id="s3-warranty" value="PHASE 2: Warranty Check&lt;br&gt;────────────────────&lt;br&gt;• Publish: postsales.warranty.defect.reported&lt;br&gt;• Legal checks warranty coverage&lt;br&gt;• Receive: warranty.coverage.verified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
