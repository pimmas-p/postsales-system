        <mxCell id="s2-trigger" value="TRIGGER&lt;br&gt;────────────────────&lt;br&gt;Auto-create from handover_completed&lt;br&gt;Publish: postsales.onboarding.started" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#6A1B9A;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="475" width="330" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="s2-steps" value="3-STEP PROCESS&lt;br&gt;────────────────────&lt;br&gt;STEP 1: Member Registration&lt;br&gt;  → Publish: postsales.member.registered&lt;br&gt;STEP 2: Document Upload&lt;br&gt;  → Manual fetch OR Auto via Kafka&lt;br&gt;STEP 3: Completion&lt;br&gt;  → Publish: postsales.profile.activated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="540" width="330" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="s2-integration" value="EXTERNAL INTEGRATION&lt;br&gt;────────────────────&lt;br&gt;• Legal Contract API (REST)&lt;br&gt;• warranty.coverage.registered (Kafka)&lt;br&gt;• Payment Team (Kafka)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="665" width="330" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s2-api" value="REST API&lt;br&gt;────────────────────&lt;br&gt;GET /api/onboarding/cases, POST /cases&lt;br&gt;PUT /cases/:id/register, PUT /cases/:id/documents&lt;br&gt;POST /cases/:id/fetch-contract, PUT /cases/:id/complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B3E5FC;strokeColor=#0277BD;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
