        <mxCell id="s3-close" value="PHASE 4: Close Case&lt;br&gt;────────────────────&lt;br&gt;• PUT /defects/:id/close&lt;br&gt;• Set resolution, closed_by&lt;br&gt;• Publish: postsales.caseclosed.completed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
