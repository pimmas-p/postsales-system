# Server Configuration
NODE_ENV=production
PORT=3001

# Backend URL (for Swagger docs)
BACKEND_URL=https://your-backend.onrender.com

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key

# CORS Configuration
FRONTEND_URL=https://your-frontend.vercel.app

# Kafka Configuration (Optional - set to false to disable Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=pkc-619z3.us-east1.gcp.confluent.cloud:9092
KAFKA_SASL_USERNAME=your-kafka-api-key
KAFKA_SASL_PASSWORD=your-kafka-api-secret
KAFKA_CONSUMER_GROUP_ID=postsales-backend-bridge-group
KAFKA_DISABLE_SSL_VERIFICATION=false
