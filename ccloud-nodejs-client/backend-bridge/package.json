{
  "name": "postsales-backend-bridge",
  "version": "1.0.0",
  "description": "Backend bridge service for Post-Sales system - Kafka to REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test-supabase-connection.js",
    "kafka:test": "node examples/test-send-kafka-event.js",
    "kafka:create-topics": "node scripts/create-kafka-topics.js",
    "kafka:check-subscribe": "node scripts/check-subscribe-topics.js",
    "kafka:send:handover": "node examples/kafka-producer-example.js 1",
    "kafka:send:onboarding": "node examples/kafka-producer-example.js 2",
    "simulate:api": "node examples/simulate-via-api.js",
    "simulate:complete": "node examples/simulate-via-api.js complete",
    "simulate:batch": "node examples/simulate-via-api.js batch"
  },
  "keywords": [
    "kafka",
    "supabase",
    "express",
    "postsales"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@confluentinc/kafka-javascript": "^1.9.0",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
